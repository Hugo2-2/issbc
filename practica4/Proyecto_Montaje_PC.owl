    </owl:Class>
    


    <!-- http://www.informatica.es/ontologies/montaje-pc#Streaming -->

    <owl:Class rdf:about="http://www.informatica.es/ontologies/montaje-pc#Streaming">
        <rdfs:subClassOf rdf:resource="http://www.informatica.es/ontologies/montaje-pc#RequisitoUso"/>
    </owl:Class>
    


    <!-- http://www.informatica.es/ontologies/montaje-pc#TarjetaGrafica -->

    <owl:Class rdf:about="http://www.informatica.es/ontologies/montaje-pc#TarjetaGrafica">
        <rdfs:subClassOf rdf:resource="http://www.informatica.es/ontologies/montaje-pc#Componente"/>
    </owl:Class>
    


