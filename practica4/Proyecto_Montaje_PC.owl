<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.informatica.es/ontologies/montaje-pc/"
     xml:base="http://www.informatica.es/ontologies/montaje-pc/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:montaje-pc="http://www.informatica.es/ontologies/montaje-pc#">
    <owl:Ontology rdf:about="http://www.informatica.es/ontologies/montaje-pc"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.informatica.es/ontologies/montaje-pc#esCompatibleCon -->

    <owl:ObjectProperty rdf:about="http://www.informatica.es/ontologies/montaje-pc#esCompatibleCon">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    </owl:ObjectProperty>
    


    <!-- http://www.informatica.es/ontologies/montaje-pc#esPiezaDe -->

    <owl:ObjectProperty rdf:about="http://www.informatica.es/ontologies/montaje-pc#esPiezaDe">
        <owl:inverseOf rdf:resource="http://www.informatica.es/ontologies/montaje-pc#tienePieza"/>
    </owl:ObjectProperty>
    


    <!-- http://www.informatica.es/ontologies/montaje-pc#orientadoA -->

    <owl:ObjectProperty rdf:about="http://www.informatica.es/ontologies/montaje-pc#orientadoA">
        <rdfs:domain rdf:resource="http://www.informatica.es/ontologies/montaje-pc#ConfiguracionPC"/>
        <rdfs:range rdf:resource="http://www.informatica.es/ontologies/montaje-pc#RequisitoUso"/>
    </owl:ObjectProperty>
    


    <!-- http://www.informatica.es/ontologies/montaje-pc#tieneAlmacenamiento -->

    <owl:ObjectProperty rdf:about="http://www.informatica.es/ontologies/montaje-pc#tieneAlmacenamiento">
        <rdfs:subPropertyOf rdf:resource="http://www.informatica.es/ontologies/montaje-pc#tienePieza"/>
        <rdfs:range rdf:resource="http://www.informatica.es/ontologies/montaje-pc#Almacenamiento"/>
    </owl:ObjectProperty>
    


    <!-- http://www.informatica.es/ontologies/montaje-pc#tieneCPU -->

    <owl:ObjectProperty rdf:about="http://www.informatica.es/ontologies/montaje-pc#tieneCPU">
        <rdfs:subPropertyOf rdf:resource="http://www.informatica.es/ontologies/montaje-pc#tienePieza"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:range rdf:resource="http://www.informatica.es/ontologies/montaje-pc#Procesador"/>
    </owl:ObjectProperty>
    


    <!-- http://www.informatica.es/ontologies/montaje-pc#tieneGPU -->

    <owl:ObjectProperty rdf:about="http://www.informatica.es/ontologies/montaje-pc#tieneGPU">
        <rdfs:subPropertyOf rdf:resource="http://www.informatica.es/ontologies/montaje-pc#tienePieza"/>
        <rdfs:range rdf:resource="http://www.informatica.es/ontologies/montaje-pc#TarjetaGrafica"/>
    </owl:ObjectProperty>
    


    <!-- http://www.informatica.es/ontologies/montaje-pc#tienePieza -->

    <owl:ObjectProperty rdf:about="http://www.informatica.es/ontologies/montaje-pc#tienePieza">
        <rdfs:domain rdf:resource="http://www.informatica.es/ontologies/montaje-pc#ConfiguracionPC"/>
        <rdfs:range rdf:resource="http://www.informatica.es/ontologies/montaje-pc#Componente"/>
    </owl:ObjectProperty>
    


    <!-- http://www.informatica.es/ontologies/montaje-pc#tienePlaca -->

    <owl:ObjectProperty rdf:about="http://www.informatica.es/ontologies/montaje-pc#tienePlaca">
        <rdfs:subPropertyOf rdf:resource="http://www.informatica.es/ontologies/montaje-pc#tienePieza"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:range rdf:resource="http://www.informatica.es/ontologies/montaje-pc#PlacaBase"/>
    </owl:ObjectProperty>
    


    <!-- http://www.informatica.es/ontologies/montaje-pc#tieneRAM -->

    <owl:ObjectProperty rdf:about="http://www.informatica.es/ontologies/montaje-pc#tieneRAM">
        <rdfs:subPropertyOf rdf:resource="http://www.informatica.es/ontologies/montaje-pc#tienePieza"/>
        <rdfs:range rdf:resource="http://www.informatica.es/ontologies/montaje-pc#MemoriaRAM"/>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.informatica.es/ontologies/montaje-pc#puntosRendimiento -->

    <owl:DatatypeProperty rdf:about="http://www.informatica.es/ontologies/montaje-pc#puntosRendimiento">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.informatica.es/ontologies/montaje-pc#Componente"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.informatica.es/ontologies/montaje-pc#tienePrecio -->

    <owl:DatatypeProperty rdf:about="http://www.informatica.es/ontologies/montaje-pc#tienePrecio">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.informatica.es/ontologies/montaje-pc#Componente"/>
                    <rdf:Description rdf:about="http://www.informatica.es/ontologies/montaje-pc#ConfiguracionPC"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.informatica.es/ontologies/montaje-pc#AMD -->

    <owl:Class rdf:about="http://www.informatica.es/ontologies/montaje-pc#AMD">
        <rdfs:subClassOf rdf:resource="http://www.informatica.es/ontologies/montaje-pc#Procesador"/>
        <owl:disjointWith rdf:resource="http://www.informatica.es/ontologies/montaje-pc#Intel"/>
    </owl:Class>
    


    <!-- http://www.informatica.es/ontologies/montaje-pc#Almacenamiento -->

    <owl:Class rdf:about="http://www.informatica.es/ontologies/montaje-pc#Almacenamiento">
        <rdfs:subClassOf rdf:resource="http://www.informatica.es/ontologies/montaje-pc#Componente"/>
    </owl:Class>
    


    <!-- http://www.informatica.es/ontologies/montaje-pc#Componente -->

    <owl:Class rdf:about="http://www.informatica.es/ontologies/montaje-pc#Componente"/>
    


    <!-- http://www.informatica.es/ontologies/montaje-pc#ConfiguracionPC -->

    <owl:Class rdf:about="http://www.informatica.es/ontologies/montaje-pc#ConfiguracionPC">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.informatica.es/ontologies/montaje-pc#tieneAlmacenamiento"/>
                <owl:someValuesFrom rdf:resource="http://www.informatica.es/ontologies/montaje-pc#Almacenamiento"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.informatica.es/ontologies/montaje-pc#tieneCPU"/>
                <owl:someValuesFrom rdf:resource="http://www.informatica.es/ontologies/montaje-pc#Procesador"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.informatica.es/ontologies/montaje-pc#tieneGPU"/>
                <owl:someValuesFrom rdf:resource="http://www.informatica.es/ontologies/montaje-pc#TarjetaGrafica"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.informatica.es/ontologies/montaje-pc#tienePlaca"/>
                <owl:someValuesFrom rdf:resource="http://www.informatica.es/ontologies/montaje-pc#PlacaBase"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.informatica.es/ontologies/montaje-pc#tieneRAM"/>
                <owl:someValuesFrom rdf:resource="http://www.informatica.es/ontologies/montaje-pc#MemoriaRAM"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.informatica.es/ontologies/montaje-pc#DDR4 -->

    <owl:Class rdf:about="http://www.informatica.es/ontologies/montaje-pc#DDR4">
        <rdfs:subClassOf rdf:resource="http://www.informatica.es/ontologies/montaje-pc#MemoriaRAM"/>
        <owl:disjointWith rdf:resource="http://www.informatica.es/ontologies/montaje-pc#DDR5"/>
    </owl:Class>
    


    <!-- http://www.informatica.es/ontologies/montaje-pc#DDR5 -->

    <owl:Class rdf:about="http://www.informatica.es/ontologies/montaje-pc#DDR5">
        <rdfs:subClassOf rdf:resource="http://www.informatica.es/ontologies/montaje-pc#MemoriaRAM"/>
    </owl:Class>
    


    <!-- http://www.informatica.es/ontologies/montaje-pc#EdicionProfesional -->

    <owl:Class rdf:about="http://www.informatica.es/ontologies/montaje-pc#EdicionProfesional">
        <rdfs:subClassOf rdf:resource="http://www.informatica.es/ontologies/montaje-pc#RequisitoUso"/>
    </owl:Class>
    


    <!-- http://www.informatica.es/ontologies/montaje-pc#FuenteAlimentacion -->

    <owl:Class rdf:about="http://www.informatica.es/ontologies/montaje-pc#FuenteAlimentacion">
        <rdfs:subClassOf rdf:resource="http://www.informatica.es/ontologies/montaje-pc#Componente"/>
    </owl:Class>
    


    <!-- http://www.informatica.es/ontologies/montaje-pc#GamaPresupuesto -->

    <owl:Class rdf:about="http://www.informatica.es/ontologies/montaje-pc#GamaPresupuesto"/>
    


    <!-- http://www.informatica.es/ontologies/montaje-pc#Gaming -->

    <owl:Class rdf:about="http://www.informatica.es/ontologies/montaje-pc#Gaming">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.informatica.es/ontologies/montaje-pc#ConfiguracionPC"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.informatica.es/ontologies/montaje-pc#tieneCPU"/>
                        <owl:someValuesFrom rdf:resource="http://www.informatica.es/ontologies/montaje-pc#AMD"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.informatica.es/ontologies/montaje-pc#tieneGPU"/>
                        <owl:someValuesFrom rdf:resource="http://www.informatica.es/ontologies/montaje-pc#NVIDIA"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.informatica.es/ontologies/montaje-pc#tieneRAM"/>
                        <owl:someValuesFrom rdf:resource="http://www.informatica.es/ontologies/montaje-pc#DDR5"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.informatica.es/ontologies/montaje-pc#ConfiguracionPC"/>
    </owl:Class>
    


    <!-- http://www.informatica.es/ontologies/montaje-pc#HDD -->

    <owl:Class rdf:about="http://www.informatica.es/ontologies/montaje-pc#HDD">
        <rdfs:subClassOf rdf:resource="http://www.informatica.es/ontologies/montaje-pc#Almacenamiento"/>
        <owl:disjointWith rdf:resource="http://www.informatica.es/ontologies/montaje-pc#SSD"/>
    </owl:Class>
    


    <!-- http://www.informatica.es/ontologies/montaje-pc#Intel -->

    <owl:Class rdf:about="http://www.informatica.es/ontologies/montaje-pc#Intel">
        <rdfs:subClassOf rdf:resource="http://www.informatica.es/ontologies/montaje-pc#Procesador"/>
    </owl:Class>
    


    <!-- http://www.informatica.es/ontologies/montaje-pc#MemoriaRAM -->

    <owl:Class rdf:about="http://www.informatica.es/ontologies/montaje-pc#MemoriaRAM">
        <rdfs:subClassOf rdf:resource="http://www.informatica.es/ontologies/montaje-pc#Componente"/>
    </owl:Class>
    


    <!-- http://www.informatica.es/ontologies/montaje-pc#NVIDIA -->

    <owl:Class rdf:about="http://www.informatica.es/ontologies/montaje-pc#NVIDIA">
        <rdfs:subClassOf rdf:resource="http://www.informatica.es/ontologies/montaje-pc#TarjetaGrafica"/>
        <owl:disjointWith rdf:resource="http://www.informatica.es/ontologies/montaje-pc#Radeon"/>
    </owl:Class>
    


    <!-- http://www.informatica.es/ontologies/montaje-pc#Ofimatica -->

    <owl:Class rdf:about="http://www.informatica.es/ontologies/montaje-pc#Ofimatica">
        <rdfs:subClassOf rdf:resource="http://www.informatica.es/ontologies/montaje-pc#RequisitoUso"/>
    </owl:Class>
    


    <!-- http://www.informatica.es/ontologies/montaje-pc#PlacaBase -->

    <owl:Class rdf:about="http://www.informatica.es/ontologies/montaje-pc#PlacaBase">
        <rdfs:subClassOf rdf:resource="http://www.informatica.es/ontologies/montaje-pc#Componente"/>
    </owl:Class>
    


    <!-- http://www.informatica.es/ontologies/montaje-pc#PresupuestoAlto -->

    <owl:Class rdf:about="http://www.informatica.es/ontologies/montaje-pc#PresupuestoAlto">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.informatica.es/ontologies/montaje-pc#ConfiguracionPC"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.informatica.es/ontologies/montaje-pc#tienePrecio"/>
                        <owl:someValuesFrom>
                            <rdfs:Datatype>
                                <owl:onDatatype rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
                                <owl:withRestrictions rdf:parseType="Collection">
                                    <rdf:Description>
                                        <xsd:minExclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1500</xsd:minExclusive>
                                    </rdf:Description>
                                </owl:withRestrictions>
                            </rdfs:Datatype>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.informatica.es/ontologies/montaje-pc#ConfiguracionPC"/>
    </owl:Class>
    


    <!-- http://www.informatica.es/ontologies/montaje-pc#PresupuestoBajo -->

    <owl:Class rdf:about="http://www.informatica.es/ontologies/montaje-pc#PresupuestoBajo">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.informatica.es/ontologies/montaje-pc#ConfiguracionPC"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.informatica.es/ontologies/montaje-pc#tienePrecio"/>
                        <owl:someValuesFrom>
                            <rdfs:Datatype>
                                <owl:onDatatype rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
                                <owl:withRestrictions rdf:parseType="Collection">
                                    <rdf:Description>
                                        <xsd:maxInclusive rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">600</xsd:maxInclusive>
                                    </rdf:Description>
                                </owl:withRestrictions>
                            </rdfs:Datatype>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.informatica.es/ontologies/montaje-pc#ConfiguracionPC"/>
    </owl:Class>
    


    <!-- http://www.informatica.es/ontologies/montaje-pc#PresupuestoMedio -->

    <owl:Class rdf:about="http://www.informatica.es/ontologies/montaje-pc#PresupuestoMedio">
        <rdfs:subClassOf rdf:resource="http://www.informatica.es/ontologies/montaje-pc#ConfiguracionPC"/>
    </owl:Class>
    


    <!-- http://www.informatica.es/ontologies/montaje-pc#Procesador -->

    <owl:Class rdf:about="http://www.informatica.es/ontologies/montaje-pc#Procesador">
        <rdfs:subClassOf rdf:resource="http://www.informatica.es/ontologies/montaje-pc#Componente"/>
    </owl:Class>
    


    <!-- http://www.informatica.es/ontologies/montaje-pc#Programacion -->

    <owl:Class rdf:about="http://www.informatica.es/ontologies/montaje-pc#Programacion">
        <rdfs:subClassOf rdf:resource="http://www.informatica.es/ontologies/montaje-pc#RequisitoUso"/>
    </owl:Class>
    


    <!-- http://www.informatica.es/ontologies/montaje-pc#Radeon -->

    <owl:Class rdf:about="http://www.informatica.es/ontologies/montaje-pc#Radeon">
        <rdfs:subClassOf rdf:resource="http://www.informatica.es/ontologies/montaje-pc#TarjetaGrafica"/>
    </owl:Class>
    


    <!-- http://www.informatica.es/ontologies/montaje-pc#RequisitoUso -->

    <owl:Class rdf:about="http://www.informatica.es/ontologies/montaje-pc#RequisitoUso"/>
    


    <!-- http://www.informatica.es/ontologies/montaje-pc#SSD -->

    <owl:Class rdf:about="http://www.informatica.es/ontologies/montaje-pc#SSD">
